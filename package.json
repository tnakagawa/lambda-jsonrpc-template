    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "json-rpc-2.0": "^1.7.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
